{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", "src-tauri/target/**"],
      "inputs": [
        "src/**",
        "src-tauri/src/**",
        "src-tauri/Cargo.toml",
        "src-tauri/tauri.conf.json",
        "rollup.config.*",
        "vite.config.*",
        "package.json"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["wdio-logs/**", "logs/**"],
      "inputs": ["test/**", "wdio.conf.js", "wdio.conf.ts", "wdio.*.conf.ts"]
    },
    "test:official": {
      "dependsOn": ["build"],
      "outputs": ["logs/**"],
      "inputs": ["test/**", "wdio.official.conf.ts"]
    },
    "test:crabnebula": {
      "dependsOn": ["build"],
      "outputs": ["logs/**"],
      "inputs": ["test/**", "wdio.crabnebula.conf.ts"],
      "env": ["CN_API_KEY"]
    },
    "test:embedded": {
      "dependsOn": ["build"],
      "outputs": ["logs/**"],
      "inputs": ["test/**", "wdio.embedded.conf.ts"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", "test/**", "*.js", "*.ts", "*.json", "biome.json", "eslint.config.js"]
    },
    "lint:fix": {
      "outputs": [],
      "inputs": ["src/**", "test/**", "*.js", "*.ts", "*.json", "biome.json", "eslint.config.js"]
    },
    "lint:fix:unsafe": {
      "outputs": [],
      "inputs": ["src/**", "test/**", "*.js", "*.ts", "*.json", "biome.json", "eslint.config.js"]
    },
    "format": {
      "outputs": [],
      "inputs": ["src/**", "test/**", "*.js", "*.ts", "*.json", "biome.json"]
    },
    "format:check": {
      "outputs": [],
      "inputs": ["src/**", "test/**", "*.js", "*.ts", "*.json", "biome.json"]
    },
    "clean": {
      "cache": false
    },
    "ci": {
      "dependsOn": ["format:check", "lint"],
      "outputs": ["dist/**", "wdio-logs/**", "logs/**"],
      "inputs": [
        "src/**",
        "test/**",
        "rollup.config.*",
        "vite.config.*",
        "wdio.conf.js",
        "wdio.conf.ts",
        "wdio.*.conf.ts",
        "package.json"
      ]
    },
    "ci:logs": {
      "outputs": [],
      "inputs": ["wdio-logs/**", "logs/**"]
    }
  }
}
