{
  "name": "@wdio-desktop-mobile-example/dioxus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cargo build",
    "clean": "rm -rf ./target ./logs ./node_modules pnpm-lock.yaml",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "lint": "biome check --formatter-enabled=false --linter-enabled=true . && eslint \"test/**/*.{j,t}s\"",
    "lint:fix": "biome check --write --formatter-enabled=false --linter-enabled=true . && eslint \"test/**/*.{j,t}s\" --fix",
    "lint:fix:unsafe": "biome check --write --formatter-enabled=false --linter-enabled=true --unsafe . && eslint \"test/**/*.{j,t}s\" --fix",
    "test": "wdio run ./wdio.conf.ts",
    "test:multiremote": "wdio run ./wdio.multiremote.conf.ts",
    "test:standalone": "node ./scripts/run-standalone.mjs",
    "test:window": "wdio run ./wdio.window.conf.ts",
    "test:visual": "wdio run ./wdio.visual.conf.ts && wdio run ./wdio.visual.conf.ts",
    "test:video": "wdio run ./wdio.video.conf.ts",
    "ci": "pnpm build && pnpm test",
    "ci:logs": "if [ -d ./logs ]; then find ./logs -type f -name '*.log' -exec sh -c 'echo \"=== $1 ===\"; cat \"$1\"' _ {} \\;; else echo 'No logs directory found'; fi"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@wdio/cli": "catalog:default",
    "@wdio/dioxus-service": "catalog:default",
    "@wdio/globals": "catalog:default",
    "@wdio/local-runner": "catalog:default",
    "@wdio/mocha-framework": "catalog:default",
    "@wdio/types": "catalog:default",
    "@wdio/visual-service": "catalog:default",
    "@wdio/xvfb": "catalog:default",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "wdio-video-reporter": "catalog:default",
    "webdriverio": "catalog:default"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
