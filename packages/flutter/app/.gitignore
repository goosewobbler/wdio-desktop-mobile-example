# `flutter create`/`flutter build` is ever run in-place.
/android/
/ios/
/linux/
/macos/
/windows/
/web/
/build/
/.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock
*.iml
.packages

