{
  "name": "@wdio-desktop-mobile-example/tauri",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "vite",
    "build": "pnpm build:js && pnpm build:rust",
    "build:js": "vite build",
    "build:rust": "tauri build --debug",
    "clean": "rm -rf ./dist ./target ./logs ./node_modules pnpm-lock.yaml",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "lint": "biome check --formatter-enabled=false --linter-enabled=true . && eslint \"test/**/*.{j,t}s\"",
    "lint:fix": "biome check --write --formatter-enabled=false --linter-enabled=true . && eslint \"test/**/*.{j,t}s\" --fix",
    "lint:fix:unsafe": "biome check --write --formatter-enabled=false --linter-enabled=true --unsafe . && eslint \"test/**/*.{j,t}s\" --fix",
    "test": "pnpm test:embedded",
    "test:official": "wdio run ./wdio.official.conf.ts",
    "test:official:multiremote": "wdio run ./wdio.official.multiremote.conf.ts",
    "test:official:deeplink": "wdio run ./wdio.official.deeplink.conf.ts",
    "test:official:standalone": "node ./scripts/run-standalone.mjs official",
    "test:official:window": "wdio run ./wdio.official.window.conf.ts",
    "test:official:visual": "wdio run ./wdio.official.visual.conf.ts && wdio run ./wdio.official.visual.conf.ts",
    "test:official:video": "wdio run ./wdio.official.video.conf.ts",
    "test:crabnebula": "wdio run ./wdio.crabnebula.conf.ts",
    "test:crabnebula:multiremote": "wdio run ./wdio.crabnebula.multiremote.conf.ts",
    "test:crabnebula:deeplink": "wdio run ./wdio.crabnebula.deeplink.conf.ts",
    "test:crabnebula:standalone": "node ./scripts/run-standalone.mjs crabnebula",
    "test:crabnebula:window": "wdio run ./wdio.crabnebula.window.conf.ts",
    "test:crabnebula:visual": "wdio run ./wdio.crabnebula.visual.conf.ts && wdio run ./wdio.crabnebula.visual.conf.ts",
    "test:crabnebula:video": "wdio run ./wdio.crabnebula.video.conf.ts",
    "test:embedded": "wdio run ./wdio.embedded.conf.ts",
    "test:embedded:multiremote": "wdio run ./wdio.embedded.multiremote.conf.ts",
    "test:embedded:deeplink": "wdio run ./wdio.embedded.deeplink.conf.ts",
    "test:embedded:standalone": "node ./scripts/run-standalone.mjs embedded",
    "test:embedded:window": "wdio run ./wdio.embedded.window.conf.ts",
    "test:embedded:visual": "wdio run ./wdio.embedded.visual.conf.ts && wdio run ./wdio.embedded.visual.conf.ts",
    "test:embedded:video": "wdio run ./wdio.embedded.video.conf.ts",
    "ci": "pnpm build && pnpm test",
    "ci:official": "pnpm build && pnpm test:official",
    "ci:crabnebula": "pnpm build && pnpm test:crabnebula",
    "ci:embedded": "pnpm build && pnpm test:embedded",
    "ci:logs": "if [ -d ./logs ]; then find ./logs -type f -name '*.log' -exec sh -c 'echo \"=== $1 ===\"; cat \"$1\"' _ {} \\;; else echo 'No logs directory found'; fi"
  },
  "dependencies": {
    "@tauri-apps/api": "catalog:default",
    "@tauri-apps/plugin-deep-link": "catalog:default",
    "@tauri-apps/plugin-log": "catalog:default",
    "@wdio/tauri-plugin": "catalog:default"
  },
  "devDependencies": {
    "@crabnebula/tauri-driver": "catalog:default",
    "@crabnebula/test-runner-backend": "catalog:default",
    "@tauri-apps/cli": "catalog:default",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.4",
    "@vitest/spy": "^4.1.9",
    "@wdio/cli": "catalog:default",
    "@wdio/globals": "catalog:default",
    "@wdio/local-runner": "catalog:default",
    "@wdio/mocha-framework": "catalog:default",
    "@wdio/tauri-service": "catalog:default",
    "@wdio/types": "catalog:default",
    "@wdio/visual-service": "catalog:default",
    "@wdio/xvfb": "catalog:default",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "wdio-video-reporter": "catalog:default",
    "webdriverio": "catalog:default"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
